<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ScgProtoTest</AssemblyName>
    <RootNamespace>ScgProtoTest</RootNamespace>
  </PropertyGroup>

  <!--
    Google.Protobuf NuGet package.
    Version 3.25.x matches protoc 25.x (libprotobuf 4.25.x).
    Make sure the version here matches whatever protoc you run to regenerate
    the generated/csharp/ScgTest.cs file.
  -->
  <ItemGroup>
    <PackageReference Include="Google.Protobuf" Version="3.25.3" />
  </ItemGroup>

  <!-- Include the generated protobuf C# file -->
  <ItemGroup>
    <Compile Include="..\generated\csharp\ScgTest.cs" />
  </ItemGroup>

  <!-- Copy the test binary to the output directory so the default path works -->
  <ItemGroup>
    <None Update="..\binary\scg_test.pb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scg_test.pb</Link>
    </None>
  </ItemGroup>

</Project>
